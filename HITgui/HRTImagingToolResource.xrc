  <object class="wxDialog" name="wxHITDialog_Base">
    <style>wxDEFAULT_DIALOG_STYLE|wxRESIZE_BORDER</style>
    <title>HRT Imaging Tool</title>
    <centered>1</centered>
    <object class="wxFlexGridSizer" name="fgSizer1">
      <minsize>800,600</minsize>
      <vgap>0</vgap>
      <hgap>0</hgap>
      <growablerows>0</growablerows>
      <growablecols>1</growablecols>
      <rows>0</rows>
      <cols>2</cols>
      <object class="sizeritem">
        <flag>wxALL|wxEXPAND</flag>
        <border>5</border>
        <option>0</option>
        <object class="wxListBox" name="m_listBoxFiles">
          <style>wxLB_EXTENDED</style>
          <content/>
        </object>
      </object>
      <object class="sizeritem">
        <flag>wxALL|wxEXPAND</flag>
        <border>5</border>
        <option>0</option>
        <object class="wxTextCtrl" name="m_textCtrlLog">
          <style>wxTE_MULTILINE|wxTE_READONLY</style>
          <value></value>
          <maxlength>0</maxlength>
        </object>
      </object>
      <object class="sizeritem">
        <flag></flag>
        <border>5</border>
        <option>0</option>
        <object class="wxBoxSizer" name="bSizer1">
          <orient>wxHORIZONTAL</orient>
          <object class="sizeritem">
            <flag>wxALIGN_CENTER_VERTICAL|wxALL</flag>
            <border>5</border>
            <option>0</option>
            <object class="wxButton" name="m_buttonAddFiles">
              <label>Add ...</label>
              <default>0</default>
              <auth_needed>0</auth_needed>
              <markup>0</markup>
              <bitmap/>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxALIGN_CENTER_VERTICAL|wxALL</flag>
            <border>5</border>
            <option>0</option>
            <object class="wxButton" name="m_buttonRemoveFiles">
              <label>Remove</label>
              <default>0</default>
              <auth_needed>0</auth_needed>
              <markup>0</markup>
              <bitmap/>
            </object>
          </object>
        </object>
      </object>
      <object class="sizeritem">
        <flag>wxEXPAND</flag>
        <border>5</border>
        <option>0</option>
        <object class="wxBoxSizer" name="bSizer2">
          <orient>wxHORIZONTAL</orient>
          <object class="sizeritem">
            <flag>wxALIGN_CENTER_VERTICAL|wxALL</flag>
            <border>5</border>
            <option>1</option>
            <object class="wxStaticText" name="m_staticTextState">
              <style>wxALIGN_CENTER_HORIZONTAL</style>
              <label>MyLabel</label>
              <wrap>-1</wrap>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxALL|wxALIGN_CENTER_VERTICAL</flag>
            <border>5</border>
            <option>0</option>
            <object class="wxButton" name="m_buttonStartStop">
              <label>Start</label>
              <default>0</default>
              <auth_needed>0</auth_needed>
              <markup>0</markup>
              <bitmap/>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxALL|wxALIGN_CENTER_VERTICAL</flag>
            <border>5</border>
            <option>0</option>
            <object class="wxButton" name="m_buttonClose">
              <label>Close</label>
              <default>0</default>
              <auth_needed>0</auth_needed>
              <markup>0</markup>
              <bitmap/>
            </object>
          </object>
        </object>
      </object>
    </object>
  </object>
  <object class="wxDialog" name="wxHITLive_Base">
    <size>714,542</size>
    <style>wxDEFAULT_DIALOG_STYLE|wxMAXIMIZE_BOX|wxMINIMIZE_BOX|wxRESIZE_BORDER</style>
    <title>HRT Online Imaging Tool</title>
    <centered>1</centered>
    <object class="wxFlexGridSizer" name="fgSizer11">
      <vgap>0</vgap>
      <hgap>0</hgap>
      <growablerows>0</growablerows>
      <growablecols>0</growablecols>
      <rows>0</rows>
      <cols>2</cols>
      <object class="sizeritem">
        <flag>wxEXPAND|wxRIGHT</flag>
        <border>5</border>
        <option>1</option>
        <object class="wxFlexGridSizer" name="fgSizer14">
          <vgap>0</vgap>
          <hgap>0</hgap>
          <growablerows>0</growablerows>
          <growablecols>0</growablecols>
          <rows>1</rows>
          <cols>1</cols>
          <object class="sizeritem">
            <flag>wxEXPAND | wxALL</flag>
            <border>5</border>
            <option>2</option>
            <object class="wxPanel" name="m_LiveImageWindow" subclass="wxTripleImagePanel">
              <style>wxTAB_TRAVERSAL</style>
              <bg>#e3e3e3</bg>
            </object>
          </object>
        </object>
      </object>
      <object class="sizeritem">
        <flag>wxEXPAND|wxALIGN_RIGHT</flag>
        <border>5</border>
        <option>1</option>
        <object class="wxFlexGridSizer" name="fgSizer12">
          <vgap>0</vgap>
          <hgap>0</hgap>
          <growablerows>2</growablerows>
          <growablecols></growablecols>
          <rows>5</rows>
          <cols>1</cols>
          <object class="sizeritem">
            <flag>wxALL|wxEXPAND</flag>
            <border>5</border>
            <option>1</option>
            <object class="wxPanel" name="m_LivePreview" subclass="wxImagePanel">
              <style>wxTAB_TRAVERSAL</style>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxALL</flag>
            <border>5</border>
            <option>0</option>
            <object class="wxStaticText" name="m_lblStateBig">
              <bg>#f0f0f0</bg>
              <font>
                <size>20</size>
                <style>normal</style>
                <weight>normal</weight>
                <family>default</family>
                <underlined>0</underlined>
              </font>
              <label>MyLabel</label>
              <wrap>-1</wrap>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxALL</flag>
            <border>5</border>
            <option>0</option>
            <object class="wxStaticText" name="m_lblState">
              <label>asdf\nasdf</label>
              <wrap>-1</wrap>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxALL|wxEXPAND</flag>
            <border>5</border>
            <option>0</option>
            <object class="wxListBox" name="m_listFilenames">
              <content/>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxALL</flag>
            <border>5</border>
            <option>0</option>
            <object class="wxCheckBox" name="m_ctrlCalibPattern">
              <label>EG-Kalibriermuster</label>
              <checked>0</checked>
            </object>
          </object>
        </object>
      </object>
    </object>
  </object>
  <object class="wxDialog" name="wxHITParameterDialog_Base">
    <size>742,1615</size>
