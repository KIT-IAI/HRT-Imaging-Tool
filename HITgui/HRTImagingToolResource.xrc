											<option>0</option>
											<flag>wxALL|wxALIGN_CENTER_VERTICAL|wxEXPAND</flag>
											<border>5</border>
											<object class="wxSpinCtrl" name="m_spinCtrlPar14">
												<style>wxSP_ARROW_KEYS</style>
												<value>30</value>
												<min>0</min>
												<max>10000</max>
											</object>
										</object>
										<object class="sizeritem">
											<option>0</option>
											<flag>wxALL|wxALIGN_CENTER_VERTICAL</flag>
											<border>5</border>
