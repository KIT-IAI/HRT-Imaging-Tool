										</object>
										<object class="sizeritem">
											<option>0</option>
											<flag>wxALL|wxALIGN_CENTER_VERTICAL</flag>
											<border>5</border>
											<object class="wxStaticText" name="m_staticTextPar13">
												<label>Step size</label>
												<wrap>-1</wrap>
											</object>
										</object>
										<object class="sizeritem">
											<option>0</option>
											<flag>wxALL|wxALIGN_CENTER_VERTICAL|wxEXPAND</flag>
											<border>5</border>
											<object class="wxSpinCtrl" name="m_spinCtrlPar13">
												<style>wxSP_ARROW_KEYS</style>
												<value>3</value>
												<min>0</min>
												<max>10000</max>
											</object>
										</object>
										<object class="sizeritem">
											<option>0</option>
											<flag>wxALL|wxALIGN_CENTER_VERTICAL</flag>
											<border>5</border>
											<object class="wxStaticText" name="m_staticTextPar14">
												<label>Sector size</label>
												<wrap>-1</wrap>
											</object>
