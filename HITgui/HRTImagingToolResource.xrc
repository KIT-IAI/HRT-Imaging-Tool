          <object class="wxBoxSizer" name="bSizer3">
            <orient>wxVERTICAL</orient>
            <object class="sizeritem">
              <flag>wxALL|wxEXPAND</flag>
              <border>5</border>
              <option>0</option>
              <object class="wxStaticBoxSizer" name="sbSizer1">
                <orient>wxVERTICAL</orient>
                <label>General</label>
                <object class="sizeritem">
                  <flag>wxEXPAND</flag>
                  <border>5</border>
                  <option>0</option>
                  <object class="wxFlexGridSizer" name="fgSizer1">
